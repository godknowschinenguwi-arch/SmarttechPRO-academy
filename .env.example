# SmartTech Academy environment
DATABASE_URL="file:./prisma/dev.db"
AUTH_SECRET="replace-me-with-a-long-random-string-in-production"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Paynow (Zimbabwe) — leave unset to use the built-in sandbox gateway.
# Get these from your Paynow merchant dashboard (paynow.co.zw) to go live:
# PAYNOW_INTEGRATION_ID=""
# PAYNOW_INTEGRATION_KEY=""

# Bunny Stream (lesson video hosting) — leave unset while lessons have no real
# video attached yet. See docs/VIDEO_HOSTING.md for setup steps.
# BUNNY_STREAM_LIBRARY_ID=""
# BUNNY_STREAM_API_KEY=""
# BUNNY_STREAM_PULL_ZONE=""
# BUNNY_STREAM_TOKEN_AUTH_KEY=""
