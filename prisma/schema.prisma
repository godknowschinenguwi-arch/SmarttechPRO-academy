// SmartTech Academy — Database Schema
// SQLite for local dev; switch provider to "postgresql" for production.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------- Users & Auth ----------

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("STUDENT") // GUEST | STUDENT | INSTRUCTOR | ADMIN
  avatarUrl    String?
  headline     String?  // e.g. "CCTV Technician, Harare"
  bio          String?
  city         String?
  country      String?
  xp           Int      @default(0)
  level        Int      @default(1) // Technician level
  streakDays   Int      @default(0)
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  enrollments      Enrollment[]
  taughtCourses    Course[]           @relation("CourseInstructor")
  reviews          Review[]
  certificates     Certificate[]
  bookings         PracticalBooking[]
  quizAttempts     QuizAttempt[]
  submissions      Submission[]
  posts            ForumPost[]
  messagesSent     Message[]          @relation("MsgSender")
  messagesReceived Message[]          @relation("MsgRecipient")
  notifications    Notification[]
  badges           UserBadge[]
  favorites        Favorite[]
  payments         Payment[]
  lessonProgress   LessonProgress[]
  auditLogs        AuditLog[]
}

// ---------- Catalog ----------

model Category {
  id      String   @id @default(cuid())
  name    String   @unique
  slug    String   @unique
  icon    String? // emoji or icon key
  courses Course[]
}

model Course {
  id             String  @id @default(cuid())
  slug           String  @unique
  title          String
  subtitle       String?
  description    String
  objectives     String // JSON array of learning objectives
  requirements   String // JSON array
  resources      String // JSON array of included resources
  imageUrl       String?
  previewVideoUrl String?
  difficulty     String  @default("BEGINNER") // BEGINNER | INTERMEDIATE | ADVANCED
  durationHours  Float   @default(0)
  priceCents     Int     @default(0) // USD cents; display converted per currency
  practicalFeeCents Int  @default(0) // remaining balance for hands-on session
  isPublished    Boolean @default(false)
  certificateEnabled Boolean @default(true)
  comingSoon     Boolean @default(false) // shown in the catalogue but not yet open for enrollment

  categoryId   String
  category     Category @relation(fields: [categoryId], references: [id])
  instructorId String
  instructor   User     @relation("CourseInstructor", fields: [instructorId], references: [id])

  modules      Module[]
  enrollments  Enrollment[]
  reviews      Review[]
  certificates Certificate[]
  practicals   PracticalSession[]
  favorites    Favorite[]
  forumThreads ForumThread[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Module {
  id       String   @id @default(cuid())
  title    String
  summary  String?
  order    Int
  courseId String
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons  Lesson[]

  @@unique([courseId, order])
}

model Lesson {
  id            String  @id @default(cuid())
  title         String
  order         Int
  kind          String  @default("VIDEO") // VIDEO | THEORY | PRACTICAL_VIDEO | QUIZ | ASSIGNMENT | SUMMARY
  videoUrl      String? // videos can be attached later without redesigning the course
  contentHtml   String? // theory / instructor notes
  estMinutes    Int     @default(10)
  isFreePreview Boolean @default(false)
  moduleId      String
  module        Module  @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  attachments LessonAttachment[]
  quiz        Quiz?
  assignment  Assignment?
  progress    LessonProgress[]

  @@unique([moduleId, order])
}

model LessonAttachment {
  id       String @id @default(cuid())
  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  name     String
  kind     String // PDF | PPTX | IMAGE | CODE | TEMPLATE | CHECKLIST
  fileUrl  String
  sizeKb   Int    @default(0)
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  user      User     @relation(fields: [userId], references: [id])
  course    Course   @relation(fields: [courseId], references: [id])
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  @@unique([userId, courseId])
}

// ---------- Learning ----------

model Enrollment {
  id            String    @id @default(cuid())
  userId        String
  courseId      String
  user          User      @relation(fields: [userId], references: [id])
  course        Course    @relation(fields: [courseId], references: [id])
  status        String    @default("ACTIVE") // ACTIVE | COMPLETED | REFUNDED
  progressPct   Float     @default(0)
  startedAt     DateTime  @default(now())
  completedAt   DateTime?

  @@unique([userId, courseId])
}

model LessonProgress {
  id             String    @id @default(cuid())
  userId         String
  lessonId       String
  user           User      @relation(fields: [userId], references: [id])
  lesson         Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completed      Boolean   @default(false)
  secondsWatched Int       @default(0) // resume from last position
  bookmarked     Boolean   @default(false)
  completedAt    DateTime?

  @@unique([userId, lessonId])
}

// ---------- Assessments ----------

model Quiz {
  id           String     @id @default(cuid())
  lessonId     String     @unique
  lesson       Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  title        String
  passMarkPct  Int        @default(70)
  timeLimitMin Int?
  isFinalExam  Boolean    @default(false)
  questions    Question[]
  attempts     QuizAttempt[]
}

model Question {
  id       String @id @default(cuid())
  quizId   String
  quiz     Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)
  order    Int
  kind     String // MCQ | TRUE_FALSE | FILL_BLANK | IMAGE_MCQ | DRAG_DROP
  prompt   String
  imageUrl String?
  options  String // JSON array of options
  answer   String // JSON — correct option index(es) or accepted text
  points   Int    @default(1)
}

model QuizAttempt {
  id        String   @id @default(cuid())
  quizId    String
  userId    String
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
  scorePct  Float
  passed    Boolean
  answers   String // JSON of given answers
  createdAt DateTime @default(now())
}

model Assignment {
  id          String       @id @default(cuid())
  lessonId    String       @unique
  lesson      Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  title       String
  brief       String
  submitKinds String       @default("FILE,PHOTO,VIDEO") // allowed submission types
  maxPoints   Int          @default(100)
  submissions Submission[]
}

model Submission {
  id           String    @id @default(cuid())
  assignmentId String
  userId       String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id])
  fileUrl      String
  note         String?
  grade        Int?
  feedback     String?
  gradedAt     DateTime?
  createdAt    DateTime  @default(now())
}

// ---------- Practical Training ----------

model PracticalSession {
  id          String   @id @default(cuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id])
  city        String
  venue       String
  country     String   @default("Zimbabwe")
  startsAt    DateTime
  endsAt      DateTime
  capacity    Int      @default(12)
  priceCents  Int      @default(0) // remaining balance payable
  bookings    PracticalBooking[]
}

model PracticalBooking {
  id         String   @id @default(cuid())
  sessionId  String
  userId     String
  session    PracticalSession @relation(fields: [sessionId], references: [id])
  user       User     @relation(fields: [userId], references: [id])
  status     String   @default("CONFIRMED") // PENDING_PAYMENT | CONFIRMED | ATTENDED | NO_SHOW | CANCELLED
  attendance Boolean  @default(false)
  assessmentScore Int?
  slipCode   String   @unique @default(cuid()) // attendance slip reference
  createdAt  DateTime @default(now())

  @@unique([sessionId, userId])
}

// ---------- Commerce ----------

model Payment {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  amountCents Int
  currency    String   @default("USD")
  provider    String // STRIPE | PAYPAL | PAYNOW | ECOCASH | MUKURU | BANK_TRANSFER
  purpose     String // COURSE | PRACTICAL | INSTALLMENT
  reference   String   @unique @default(cuid())
  status      String   @default("PENDING") // PENDING | PAID | FAILED | REFUNDED | REFUND_DUE
  couponCode  String?
  meta        String?  // JSON: { courseId } or { sessionId } — consumed on activation
  pollUrl     String?  // Paynow poll URL (server-side status source of truth)
  createdAt   DateTime @default(now())
}

model Coupon {
  id         String   @id @default(cuid())
  code       String   @unique
  percentOff Int
  maxUses    Int      @default(100)
  usedCount  Int      @default(0)
  expiresAt  DateTime?
  active     Boolean  @default(true)
}

// ---------- Certification ----------

model Certificate {
  id             String   @id @default(cuid())
  serial         String   @unique // e.g. STA-2026-000123
  kind           String   @default("COURSE") // COURSE | PRACTICAL
  userId         String
  courseId       String
  user           User     @relation(fields: [userId], references: [id])
  course         Course   @relation(fields: [courseId], references: [id])
  hoursCompleted Float
  issuedAt       DateTime @default(now())
}

// ---------- Community ----------

model ForumThread {
  id        String      @id @default(cuid())
  courseId  String
  course    Course      @relation(fields: [courseId], references: [id])
  title     String
  pinned    Boolean     @default(false)
  posts     ForumPost[]
  createdAt DateTime    @default(now())
}

model ForumPost {
  id        String      @id @default(cuid())
  threadId  String
  userId    String
  thread    ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id])
  body      String
  likes     Int         @default(0)
  isAnswer  Boolean     @default(false)
  createdAt DateTime    @default(now())
}

model Message {
  id          String   @id @default(cuid())
  senderId    String
  recipientId String
  sender      User     @relation("MsgSender", fields: [senderId], references: [id])
  recipient   User     @relation("MsgRecipient", fields: [recipientId], references: [id])
  body        String
  readAt      DateTime?
  createdAt   DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  kind      String // COURSE_UPDATE | ASSIGNMENT_DUE | QUIZ_RESULT | CERT_READY | PRACTICAL_REMINDER | PAYMENT
  title     String
  body      String
  href      String?
  readAt    DateTime?
  createdAt DateTime @default(now())
}

// ---------- Gamification ----------

model Badge {
  id          String      @id @default(cuid())
  key         String      @unique
  name        String
  description String
  icon        String
  users       UserBadge[]
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  user     User     @relation(fields: [userId], references: [id])
  badge    Badge    @relation(fields: [badgeId], references: [id])
  earnedAt DateTime @default(now())

  @@unique([userId, badgeId])
}

model Favorite {
  id       String @id @default(cuid())
  userId   String
  courseId String
  user     User   @relation(fields: [userId], references: [id])
  course   Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
}

// ---------- Ops ----------

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  detail    String?
  ip        String?
  createdAt DateTime @default(now())
}
